# Candango workers — environment (copy to .env; gitignored)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/candango"
REDIS_URL="redis://localhost:6379"

# Brevo — transactional email (the email worker sends invites/reset/verification)
# See vault: External Setup & Credentials §4
BREVO_API_KEY=
EMAIL_FROM=no-reply@candango.app
EMAIL_FROM_NAME=Candango

# Google (Calendar/Gmail sync workers) — same values as apps/api/.env
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/v1/integrations/google/callback
# MUST match apps/api/.env exactly (used to decrypt the stored OAuth tokens)
GOOGLE_TOKEN_ENC_KEY=

# QuickBooks (token keep-alive worker) — same values as apps/api/.env
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
QBO_REDIRECT_URI=http://localhost:4000/v1/integrations/quickbooks/callback
