# Candango API — environment variables (copy to .env and fill in; .env is gitignored)
# See vault: Candango/06 - Delivery/External Setup & Credentials.md

# Core
# Runtime connection: a NON-superuser role (subject to row-level security).
DATABASE_URL=postgresql://candango_app:candango@localhost:5432/candango?schema=public
# Migrations/introspection: the owner/superuser (can ALTER tables + RLS policies).
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/candango?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=
APP_URL=http://localhost:3000
API_URL=http://localhost:4000/v1
# Public marketing site origin (cadido-website) — allowed by CORS for the /contact form.
SITE_URL=http://localhost:4321

# Contact form (cadido-website /contact → POST /v1/contact → Brevo via the worker)
CONTACT_INBOX=hello@candango.app
# Optional anti-spam: Cloudflare Turnstile secret (server-side verify). Honeypot works without it.
TURNSTILE_SECRET=

# Google OAuth (Calendar + Gmail) — see External Setup §1
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/v1/integrations/google/callback
# "Sign in with Google" callback (register this redirect URI in the same OAuth client).
GOOGLE_AUTH_REDIRECT_URI=http://localhost:4000/v1/auth/google/callback
# Encrypts OAuth tokens at rest (AES-256-GCM). Optional in dev — falls back to JWT_SECRET.
# Generate one with: openssl rand -hex 32
GOOGLE_TOKEN_ENC_KEY=

# QuickBooks Online — see External Setup §2
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4000/v1/integrations/quickbooks/callback
QBO_ENVIRONMENT=sandbox

# Stripe — see External Setup §3
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Brevo — transactional email (invites, password reset, verification) — see External Setup §4
BREVO_API_KEY=
EMAIL_FROM=no-reply@candango.app
