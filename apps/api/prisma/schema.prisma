// SalesCRM — Prisma schema
// Multi-tenant sales CRM. Every tenant-owned model carries `orgId` for row-level
// isolation (see docs: Multi-Tenancy & Security). PostgreSQL is the primary store.
//
// Conventions:
//   - All models use cuid() string IDs.
//   - createdAt / updatedAt on every model; soft-delete via deletedAt where relevant.
//   - Composite indexes lead with orgId.
//   - Money stored as integer minor units (cents) + currency code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy & Identity
// ---------------------------------------------------------------------------

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  plan            String   @default("trial") // trial | standard
  onboardingState Json     @default("{}")     // { pipelineCreated, teammatesInvited, ... }
  dealSeq         Int      @default(0)         // per-tenant counter for human-readable Deal.refNumber
  logoUrl         String?   // workspace logo (data URL for now; object storage in production)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  users        User[]
  teams        Team[]
  roles        Role[]
  pipelines    Pipeline[]
  stages       Stage[]
  deals        Deal[]
  persons      Person[]
  companies    Company[]
  activities   Activity[]
  notes        Note[]
  webhooks     Webhook[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  eventOutbox  EventOutbox[]
  messages     Message[]
  subscription Subscription?
  invoices     Invoice[]
  customFieldDefinitions CustomFieldDefinition[]
  quickbooksConnection QuickBooksConnection?
  quickbooksCustomerLinks QuickBooksCustomerLink[]
  dealEstimates  DealEstimate[]
  dealInvoices   DealInvoice[]
}

model User {
  id           String   @id @default(cuid())
  orgId        String
  email        String
  name         String?
  phone        String?
  avatarUrl    String?  // data URL for now; object storage in production
  passwordHash String?
  status       String   @default("active") // active | invited | deactivated
  roleId       String?
  teamId       String?
  lastLoginAt  DateTime?
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  organization       Organization        @relation(fields: [orgId], references: [id])
  role               Role?               @relation(fields: [roleId], references: [id])
  team               Team?               @relation("TeamMembers", fields: [teamId], references: [id])
  ownedDeals         Deal[]              @relation("DealOwner")
  ownedPersons       Person[]            @relation("PersonOwner")
  ownedCompanies     Company[]           @relation("CompanyOwner")
  assignedActivities Activity[]          @relation("ActivityAssignee")
  notes              Note[]
  calendarConnection CalendarConnection?
  mailboxConnection  MailboxConnection?
  managedTeams       Team[]              @relation("TeamManager")
  authTokens         AuthToken[]

  @@unique([orgId, email])
  @@index([orgId, status])
}

/// Single-use, hashed tokens for member invites, password resets, and email verification.
/// Only the SHA-256 hash is stored; the raw token is emailed via Brevo (see Transactional Email).
model AuthToken {
  id        String    @id @default(cuid())
  orgId     String
  userId    String
  type      String    // invite | password_reset | email_verify
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model Team {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  managerUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  manager      User?        @relation("TeamManager", fields: [managerUserId], references: [id])
  members      User[]       @relation("TeamMembers")

  @@index([orgId])
}

model Role {
  id          String   @id @default(cuid())
  orgId       String?  // null for system roles
  name        String
  isSystem    Boolean  @default(false)
  permissions Json     @default("[]") // scope strings: ["deals:read", ...]
  visibility  String   @default("own") // own | team | org
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id])
  users        User[]

  @@index([orgId])
}

// ---------------------------------------------------------------------------
// Pipelines & Stages
// ---------------------------------------------------------------------------

model Pipeline {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  isDefault Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id])
  stages       Stage[]
  deals        Deal[]

  @@index([orgId])
}

model Stage {
  id          String   @id @default(cuid())
  orgId       String
  pipelineId  String
  name        String
  position    Int      @default(0)
  probability Int      @default(0) // 0-100
  rottingDays Int?     // idle threshold; null = no rotting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id])
  deals        Deal[]

  @@index([orgId, pipelineId])
}

// ---------------------------------------------------------------------------
// Deals, Contacts & Activities
// ---------------------------------------------------------------------------

model Deal {
  id                 String   @id @default(cuid())
  orgId              String
  refNumber          Int?     // human-readable per-tenant deal number (Pipedrive-style); cuid stays the real id
  title              String
  value              Int      @default(0) // minor units
  currency           String   @default("USD")
  pipelineId         String
  stageId            String
  ownerUserId        String
  primaryPersonId    String?
  companyId          String?
  status             String   @default("open") // open | won | lost
  lostReason         String?
  expectedCloseDate  DateTime?
  stageChangedAt     DateTime @default(now())
  customFields       Json     @default("{}")
  // QuickBooks (optional; null when QBO not connected)
  qbSubcustomerId    String?  // QBO sub-customer (Job) id for this deal
  shipTo             Json?    // work/job-site address -> QBO ShipAddr
  billTo             Json?    // payer details -> QBO BillAddr
  valueOverridden    Boolean  @default(false) // when true, estimate sync won't overwrite value
  archivedAt         DateTime? // archived = hidden from active board/list but kept (distinct from deletedAt)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  organization Organization      @relation(fields: [orgId], references: [id])
  pipeline     Pipeline          @relation(fields: [pipelineId], references: [id])
  stage        Stage             @relation(fields: [stageId], references: [id])
  owner        User              @relation("DealOwner", fields: [ownerUserId], references: [id])
  primaryPerson Person?          @relation("DealPrimaryPerson", fields: [primaryPersonId], references: [id])
  company      Company?          @relation(fields: [companyId], references: [id])
  participants DealParticipant[]
  activities   Activity[]
  notes        Note[]
  messages     Message[]
  stageEvents  DealStageEvent[]
  estimates    DealEstimate[]
  invoices     DealInvoice[]

  @@unique([orgId, refNumber])
  @@index([orgId, stageId])
  @@index([orgId, ownerUserId])
  @@index([orgId, status])
}

model Person {
  id           String   @id @default(cuid())
  orgId        String
  name         String
  emails       Json     @default("[]") // [{ value, label }]
  phones       Json     @default("[]")
  address      Json?    // structured { line1, line2, city, state, postalCode, country }; used for QBO Bill To
  ownerUserId  String?
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  organization     Organization      @relation(fields: [orgId], references: [id])
  owner            User?             @relation("PersonOwner", fields: [ownerUserId], references: [id])
  companyLinks     CompanyContact[]  // a person can be a contact at many companies
  dealParticipants DealParticipant[]
  primaryForDeals  Deal[]            @relation("DealPrimaryPerson")
  activities       Activity[]
  activityParticipations ActivityParticipant[]
  notes            Note[]
  messages         Message[]

  @@index([orgId])
}

model Company {
  id           String   @id @default(cuid())
  orgId        String
  name         String
  domain       String?
  address      Json?    // structured { line1, line2, city, state, postalCode, country }
  phone        String?
  ownerUserId  String?
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  organization Organization     @relation(fields: [orgId], references: [id])
  owner        User?            @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  contacts     CompanyContact[] // contact people at this company
  deals        Deal[]

  @@index([orgId])
  @@index([orgId, domain])
}

/// Many-to-many link between a Company and its contact People. A person can be
/// a contact at one or more companies (see Deals, Contacts & Activities).
model CompanyContact {
  companyId String
  personId  String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person  Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([companyId, personId])
  @@index([personId])
}

model DealParticipant {
  dealId   String
  personId String
  role     String? // e.g. decision-maker, influencer

  deal   Deal   @relation(fields: [dealId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@id([dealId, personId])
}

model Activity {
  id              String   @id @default(cuid())
  orgId           String
  dealId          String?
  personId        String?
  assignedUserId  String?
  type            String   // call | meeting | task | email
  subject         String
  dueAt           DateTime?
  startAt         DateTime?
  endAt           DateTime?
  location        String?
  locationType    String?  // in_person | video | phone | none
  conferenceUrl   String?
  durationMin     Int?
  done            Boolean  @default(false)
  calendarEventId String?
  googleTaskId    String?  // Google Tasks id for non-meeting activities (call/task/email)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization          @relation(fields: [orgId], references: [id])
  deal          Deal?                 @relation(fields: [dealId], references: [id])
  person        Person?               @relation(fields: [personId], references: [id])
  assignee      User?                 @relation("ActivityAssignee", fields: [assignedUserId], references: [id])
  calendarEvent CalendarEvent?
  participants  ActivityParticipant[]

  @@index([orgId, dueAt])
  @@index([orgId, dealId])
}

/// Stage-change history for a deal (FR-3.10). Logged on creation and every move.
model DealStageEvent {
  id              String   @id @default(cuid())
  orgId           String
  dealId          String
  fromStageId     String?
  toStageId       String
  changedByUserId String?
  createdAt       DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
}

model Note {
  id           String   @id @default(cuid())
  orgId        String
  dealId       String?
  personId     String?
  authorUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id])
  person       Person?      @relation(fields: [personId], references: [id])
  author       User         @relation(fields: [authorUserId], references: [id])

  @@index([orgId, dealId])
}

// ---------------------------------------------------------------------------
// Integrations: Calendar & Mailbox
// ---------------------------------------------------------------------------

model CalendarConnection {
  id           String   @id @default(cuid())
  orgId        String
  userId       String   @unique
  provider     String   @default("google")
  accessToken  String   // encrypted at rest
  refreshToken String   // encrypted at rest
  tokenExpiry  DateTime?
  syncToken    String?
  watchChannelId String?
  watchExpiry  DateTime?
  status       String   @default("connected") // connected | reauth_required | disconnected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([orgId])
}

/// People attending/involved in an activity (beyond the primary person).
/// Defaults to the deal's people on creation; editable. See FR-3.4.
model ActivityParticipant {
  activityId String
  personId   String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([activityId, personId])
  @@index([personId])
}

model CalendarEvent {
  id              String   @id @default(cuid())
  orgId           String
  activityId      String   @unique
  externalEventId String
  etag            String?
  lastSyncedAt    DateTime?
  syncDirection   String?  // inbound | outbound
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activity Activity @relation(fields: [activityId], references: [id])

  @@index([orgId, externalEventId])
}

model MailboxConnection {
  id           String   @id @default(cuid())
  orgId        String
  userId       String   @unique
  provider     String   @default("gmail")
  accessToken  String   // encrypted at rest
  refreshToken String   // encrypted at rest
  historyId    String?
  status       String   @default("connected")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([orgId])
}

model Message {
  id                String   @id @default(cuid())
  orgId             String
  userId            String
  direction         String   // in | out
  providerMessageId String
  threadId          String?
  fromAddress       String
  toAddresses       Json     @default("[]")
  subject           String?
  snippet           String?
  folder            String   @default("inbox") // primary folder hint (kept for display)
  labels            String[] @default([]) // raw Gmail labelIds — a message can be in several folders (e.g. self-email = SENT+INBOX)
  personId          String?
  dealId            String?
  sentAt            DateTime?
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], map: "Message_org_fk")
  person       Person?      @relation(fields: [personId], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id])

  @@unique([userId, providerMessageId])
  @@index([orgId, personId])
  @@index([orgId, dealId])
  @@index([userId, folder, sentAt])
}

// ---------------------------------------------------------------------------
// Platform: Webhooks, API Keys, Events, Audit
// ---------------------------------------------------------------------------

model Webhook {
  id         String   @id @default(cuid())
  orgId      String
  url        String
  secret     String   // encrypted at rest; used for HMAC signing
  eventTypes String[] // subscribed event types
  isActive   Boolean  @default(true)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id])
  deliveries   WebhookDelivery[]

  @@index([orgId])
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  orgId        String
  webhookId    String
  eventId      String
  status       String   @default("pending") // pending | success | failed
  attempt      Int      @default(0)
  responseCode Int?
  nextRetryAt  DateTime?
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id])

  @@index([orgId, status])
  @@index([webhookId])
}

model EventOutbox {
  id          String    @id @default(cuid())
  orgId       String
  entityType  String
  entityId    String
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, processedAt])
  @@index([processedAt])
}

model ApiKey {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  keyHash    String   @unique // SHA-256 of the secret
  prefix     String   // first chars shown in UI, e.g. sk_live_abc
  scopes     String[]
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  actorType  String   // user | api_key
  actorId    String
  action     String
  targetType String?
  targetId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

// ---------------------------------------------------------------------------
// Billing & Subscriptions (Stripe)
// ---------------------------------------------------------------------------

model Subscription {
  id                   String   @id @default(cuid())
  orgId                String   @unique
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  status               String   @default("trialing") // trialing | active | past_due | locked | canceled
  seats                Int      @default(1)
  pricePerSeat         Int      @default(3000) // $30.00 in cents
  currency             String   @default("USD")
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([status])
}

model Invoice {
  id              String   @id @default(cuid())
  orgId           String
  stripeInvoiceId String   @unique
  amountDue       Int
  amountPaid      Int
  currency        String   @default("USD")
  status          String   // draft | open | paid | void | uncollectible
  seats           Int?
  periodStart     DateTime?
  periodEnd       DateTime?
  hostedInvoiceUrl String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

// ---------------------------------------------------------------------------
// Custom Fields (admin-defined schema; values live in each record's custom_fields jsonb)
// ---------------------------------------------------------------------------

model CustomFieldDefinition {
  id        String   @id @default(cuid())
  orgId     String
  entity    String   // deal | person | company
  key       String   // stable key used in the record's custom_fields jsonb
  label     String
  type      String   @default("text") // text | number | date | select
  options   String[] // choices when type = select
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, entity, key])
  @@index([orgId, entity])
}

// ---------------------------------------------------------------------------
// QuickBooks Integration (optional, per-tenant — system never depends on it)
// ---------------------------------------------------------------------------

model QuickBooksConnection {
  id           String   @id @default(cuid())
  orgId        String   @unique
  realmId      String   // QBO company id
  accessToken  String   // encrypted at rest
  refreshToken String   // encrypted at rest
  tokenExpiry  DateTime?
  refreshTokenExpiry DateTime? // QBO refresh token lapses after ~100 days idle (keep-alive refresh)
  lastRefreshAt DateTime?
  lastError    String?
  status       String   @default("connected") // connected | reauth_required | disconnected
  connectedBy  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
}

// Links a client (Company or Person) to its QBO parent Customer.
// The QBO account is tied to the CLIENT and reused across all that client's deals.
model QuickBooksCustomerLink {
  id           String   @id @default(cuid())
  orgId        String
  clientType   String   // company | person
  clientId     String
  qbCustomerId String   // QBO parent Customer id
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, clientType, clientId])
  @@index([orgId])
}

// Estimates & invoices for a deal — line-item documents. `source` distinguishes
// native (Candango-created, works offline) from quickbooks (created/edited via QBO).
// Native + QBO docs coexist and are NOT synced to each other (see QuickBooks Integration).
model DealEstimate {
  id          String    @id @default(cuid())
  orgId       String
  dealId      String
  source      String    @default("native") // native | quickbooks
  status      String    @default("draft")  // draft | sent | accepted | rejected | closed
  docNumber   String?
  currency    String    @default("USD")
  totalAmount Int       @default(0) // minor units (= sum of line amounts, or QBO TotalAmt)
  txnDate     DateTime?
  notes       String?
  qbId        String?   // QBO Estimate.Id (null for native)
  qbSyncToken String?   // QBO SyncToken (required for QBO updates)
  qbSyncedAt  DateTime?
  includeInValue Boolean @default(false) // counts toward the deal value when marked
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  organization Organization       @relation(fields: [orgId], references: [id])
  deal         Deal               @relation(fields: [dealId], references: [id])
  lines        DealEstimateLine[]
  invoices     DealInvoice[]

  @@unique([orgId, source, qbId])
  @@index([orgId, dealId])
}

model DealEstimateLine {
  id          String  @id @default(cuid())
  estimateId  String
  position    Int     @default(0)
  description String
  quantity    Int     @default(1)
  unitPrice   Int     @default(0) // minor units
  amount      Int     @default(0) // minor units (= quantity * unitPrice, server-computed)
  qbLineId    String?
  itemId      String? // QBO Item (Product/Service) ref id
  itemName    String? // QBO Item display name (cached for display)

  estimate DealEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model DealInvoice {
  id               String    @id @default(cuid())
  orgId            String
  dealId           String
  source           String    @default("native") // native | quickbooks
  status           String    @default("draft")  // draft | sent | paid | void
  docNumber        String?
  currency         String    @default("USD")
  totalAmount      Int       @default(0)
  txnDate          DateTime?
  notes            String?
  sourceEstimateId String?   // primary local DealEstimate this invoice was generated from
  sourceEstimateIds String[] @default([]) // all local estimates combined into this invoice
  includeInValue   Boolean  @default(true) // invoices count toward deal value by default; can be unmarked
  qbId             String?
  qbSyncToken      String?
  qbSyncedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  organization   Organization      @relation(fields: [orgId], references: [id])
  deal           Deal              @relation(fields: [dealId], references: [id])
  sourceEstimate DealEstimate?     @relation(fields: [sourceEstimateId], references: [id])
  lines          DealInvoiceLine[]

  @@unique([orgId, source, qbId])
  @@index([orgId, dealId])
}

model DealInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  position    Int     @default(0)
  description String
  quantity    Int     @default(1)
  unitPrice   Int     @default(0)
  amount      Int     @default(0)
  qbLineId    String?
  itemId      String? // QBO Item (Product/Service) ref id
  itemName    String? // QBO Item display name (cached for display)

  invoice DealInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}
